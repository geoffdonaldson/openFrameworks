# libvorbis pkg-config source file

prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include

Name: vorbis
Description: vorbis is the primary Ogg Vorbis library
Version: 1.3.3
Requires: ogg
Conflicts:
Libs: -L${libdir} -lvorbis -lm
Cflags: -I${includedir}
