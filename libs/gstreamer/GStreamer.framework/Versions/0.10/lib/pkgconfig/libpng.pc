prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include/libpng15

Name: libpng
Description: Loads and saves PNG files
Version: 1.5.12
Libs: -L${libdir} -lpng15
Libs.private: -lz 
Cflags: -I${includedir}
