prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include

Name: FLAC
Description: Free Lossless Audio Codec Library
Version: 1.2.1
Libs: -L${libdir} -lFLAC -lm
Cflags: -I${includedir}/FLAC
