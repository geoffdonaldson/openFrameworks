prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include

Name: Pango Cairo
Description: Cairo rendering support for Pango
Version: 1.30.1
Requires: pango cairo  pangoft2
Libs: -L${libdir} -lpangocairo-1.0
Cflags: -I${includedir}/pango-1.0
