prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include/

Name: libmms
Description: Library implementing the MMS protocol 
Requires: glib-2.0
Version: 0.6.2
Libs: -L${libdir} -lmms -lm
Cflags: -I${includedir}
