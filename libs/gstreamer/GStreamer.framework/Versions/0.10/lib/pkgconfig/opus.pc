# opus codec reference implementation pkg-config file

prefix=/Library/Frameworks/GStreamer.framework/Versions/0.10
exec_prefix=${prefix}
libdir=/Library/Frameworks/GStreamer.framework/Versions/0.10/lib
includedir=${prefix}/include

Name: Opus
Description: Opus IETF low-latency audio codec
URL: http://opus-codec.org/
Version: 1.0.1
Requires:
Conflicts:
Libs: -L${libdir} -lopus
Cflags: -I${includedir}/opus
